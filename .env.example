# StewardAI environment. Copy to .env and fill secrets. (.env is git-ignored.)

# --- LLM (Gemini via LiteLLM) ---
# Reuse your existing Gemini key (e.g. from the standin project).
GEMINI_API_KEY=your-gemini-key
# Model name as stored (e.g. gemini-2.0-flash). LiteLLM model string is derived
# as gemini/<GEMINI_MODEL> unless LLM_MODEL is set explicitly.
GEMINI_MODEL=gemini-2.0-flash
# Optional explicit override; switch models/providers by changing THIS value only.
# LLM_MODEL=gemini/gemini-2.0-flash

# --- Backends (stub = no heavy deps; real backends need the cpu/cuda extra) ---
STT_BACKEND=stub          # stub | parakeet_nemo
TTS_BACKEND=stub          # stub | kokoro
LLM_BACKEND=litellm       # stub | litellm
TURN_DETECTOR=silence     # silence | silero

# --- Compute ---
DEVICE=cpu                # cpu | cuda  (the ONLY switch between dev and GPU prod)

# --- Vexa <-> agent bridge ---
BRIDGE_TRANSPORT=tcp      # tcp (Mac/dev) | unix (Linux co-located)
BRIDGE_TCP_HOST=127.0.0.1
BRIDGE_TCP_PORT=8765
BRIDGE_SOCKET_PATH=/tmp/stewardai.sock

# --- TTS ---
TTS_DEFAULT_VOICE=stub

# --- Logging ---
LOG_LEVEL=info            # debug | info | warning | error
LOG_FORMAT=json           # json | console
