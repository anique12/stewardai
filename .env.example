# StewardAI environment. Copy to .env and fill secrets. (.env is git-ignored.)

# --- LLM (Gemini via LiteLLM) ---
# Reuse your existing Gemini key (e.g. from the standin project).
GEMINI_API_KEY=your-gemini-key
# Model name as stored. LiteLLM model string is derived as gemini/<GEMINI_MODEL>
# unless LLM_MODEL is set. Bump the tier here for smarter replies (no GPU involved).
GEMINI_MODEL=gemini-2.5-flash-lite
# LLM_MODEL=gemini/gemini-2.0-flash
LLM_TIMEOUT_S=20          # backstop so a stalled LLM stream can't silently hang a turn

# --- Backends (stub = no heavy deps) ---
# STT_BACKEND: whisper (=faster_whisper) | parakeet (=parakeet_nemo) | stub
STT_BACKEND=stub
TTS_BACKEND=stub          # stub | piper | kokoro
LLM_BACKEND=litellm       # stub | litellm
TURN_DETECTOR=silence     # silence | silero  (only the /stt component page)

# --- Whisper STT (faster-whisper / CTranslate2) — multilingual ---
# large-v3 = accurate + 99 languages; turbo is faster but a notch less accurate.
WHISPER_MODEL=large-v3
# WHISPER_COMPUTE_TYPE: leave blank -> int8 (cpu) / float16 (cuda)
WHISPER_COMPUTE_TYPE=
# WHISPER_BEAM_SIZE: greedy=1; raise (e.g. 5) for accuracy at higher latency
WHISPER_BEAM_SIZE=1
# WHISPER_LANGUAGE: leave blank -> auto-detect per utterance (multilingual).
# Pin to a code (e.g. en) to force one language (faster, no mis-detection).
WHISPER_LANGUAGE=

# --- Parakeet STT (NVIDIA NeMo) — needs the `parakeet` extra + GPU ---
# v3 = multilingual (25 European langs); v2 = English-only, a touch better on EN.
PARAKEET_MODEL=nvidia/parakeet-tdt-0.6b-v3

# --- Piper TTS (local neural) ---
PIPER_DATA_DIR=~/.cache/stewardai/piper   # voice .onnx downloads here on first use

# --- Turn detection / endpointing (LiveKit AgentSession config) ---
# min_delay must exceed STT latency so the EOU check runs before the turn flushes.
# CPU (slow STT): 2.0 / 4.0. GPU (fast STT): drop to ~0.5 / 2.0 for snappy turns.
TURN_MIN_DELAY=2.0
TURN_MAX_DELAY=4.0
VAD_ACTIVATION_THRESHOLD=0.6   # higher = ignore quieter/distant background speech
VAD_MIN_SPEECH_DURATION=0.2
INTERRUPTION_MIN_WORDS=2        # >=N words before a barge-in cuts off the agent
# false = a barge-in definitively stops the agent (no pause-then-resume).
RESUME_FALSE_INTERRUPTION=false
# barge-in responsiveness: vad = fast (cut off on voice); adaptive = smarter but ~1-2s slower.
INTERRUPTION_MODE=vad
INTERRUPTION_MIN_DURATION=0.25   # seconds of speech before a barge-in registers

# --- Compute ---
DEVICE=cpu                # cpu | cuda  (the ONLY switch between dev and GPU prod)

# --- Vexa <-> agent bridge ---
BRIDGE_TRANSPORT=tcp      # tcp (Mac/dev) | unix (Linux co-located)
BRIDGE_TCP_HOST=127.0.0.1
BRIDGE_TCP_PORT=8765
BRIDGE_SOCKET_PATH=/tmp/stewardai.sock

# --- TTS ---
TTS_DEFAULT_VOICE=stub    # piper: en_US-lessac-medium | kokoro: af_heart | stub: stub

# --- Logging ---
LOG_LEVEL=info            # debug | info | warning | error
LOG_FORMAT=json           # json | console

# =====================================================================
# GPU prod profile — set these on the L4 box (.env on the VM):
#   DEVICE=cuda
#   STT_BACKEND=faster_whisper
#   WHISPER_MODEL=large-v3-turbo
#   TTS_BACKEND=piper            (or kokoro)
#   TTS_DEFAULT_VOICE=en_US-lessac-medium
#   TURN_MIN_DELAY=0.5           (GPU STT is fast — retune after measuring)
#   TURN_MAX_DELAY=2.0
# =====================================================================
