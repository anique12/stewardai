NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
GOOGLE_OAUTH_CLIENT_ID=<client-id>
GOOGLE_OAUTH_CLIENT_SECRET=<client-secret>
NEXT_PUBLIC_DEMO_WS_URL=wss://api.meetbase.site/ws/pipeline  # prod (TLS via Caddy → backend :8080)
DEMO_TOKEN_SECRET=<32-byte-hex>
NEXT_PUBLIC_ASK_API_URL=  # base URL of the Python Ask API (e.g. https://your-cx33-domain)
NEXT_PUBLIC_CHAT_WS_URL=wss://api.meetbase.site/ws/chat  # prod; ws://<backend-host>:8080/ws/chat locally
